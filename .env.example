# ---- Music generation ----
# Which provider to use. Options:
#   "elevenlabs" (default, recommended)  — real. Requires ELEVENLABS_API_KEY below.
#   "replicate"                           — real, alternate. Requires REPLICATE_API_TOKEN below.
#   "mock"                                — local fallback, seeded sine-wave stems. Labeled in UI.
GENERATED_MUSIC_PROVIDER=elevenlabs

# ElevenLabs Music — primary real provider.
# Create a key at https://elevenlabs.io/app/settings/api-keys
# Your account must have Music API access enabled.
ELEVENLABS_API_KEY=
# Optional. Leave blank to let ElevenLabs pick the default music model.
ELEVENLABS_MUSIC_MODEL=

# Replicate — alternate real provider (meta/musicgen).
# Only needed if you set GENERATED_MUSIC_PROVIDER=replicate.
# Create one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_MUSIC_MODEL=meta/musicgen
# Optional. Pin a specific model version hash to skip auto-resolve.
REPLICATE_MUSIC_VERSION=

# ---- Video render / export ----
# "ffmpeg"       = real mix baked into exported MP4 (recommended). Requires ffmpeg on PATH.
#                  Aspect ratio and resolution are preserved from the source — no bars.
# "preview-copy" = honest fallback. Exports a copy of the source video; live in-browser mix
#                  is still audible in the studio, but not baked into the file.
MEDIA_RENDERER_PROVIDER=ffmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
