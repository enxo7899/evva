# ---- Music generation ----
# Which provider to use. Options:
#   "elevenlabs" (default, recommended)  — real. Requires ELEVENLABS_API_KEY below.
#   "replicate"                           — real, alternate. Requires REPLICATE_API_TOKEN below.
#   "mock"                                — local fallback, seeded sine-wave stems. Labeled in UI.
GENERATED_MUSIC_PROVIDER=elevenlabs

# ElevenLabs Music — primary real provider.
# Create a key at https://elevenlabs.io/app/settings/api-keys
# Your account must have Music API access enabled.
ELEVENLABS_API_KEY=
# Optional. Leave blank to let ElevenLabs pick the default music model.
ELEVENLABS_MUSIC_MODEL=

# Replicate — alternate real provider (meta/musicgen).
# Only needed if you set GENERATED_MUSIC_PROVIDER=replicate.
# Create one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_MUSIC_MODEL=meta/musicgen
# Optional. Pin a specific model version hash to skip auto-resolve.
REPLICATE_MUSIC_VERSION=

# ---- Video render / export ----
# "ffmpeg"       = real mix baked into exported MP4 (recommended). Uses the
#                  bundled @ffmpeg-installer binary on Vercel, or the one on
#                  PATH locally. Aspect ratio and resolution are preserved.
# "preview-copy" = honest fallback. Exports a copy of the source video; live
#                  in-browser mix is still audible in the studio, but not
#                  baked into the file.
MEDIA_RENDERER_PROVIDER=ffmpeg
# Optional override. Leave blank on Vercel — the bundled @ffmpeg-installer
# binary is used automatically. Set a custom path for non-standard local
# installs.
FFMPEG_PATH=
FFPROBE_PATH=

# ---- Storage (Vercel Blob) ----
# Required for production deploys. Create a Blob store in the Vercel
# dashboard → Storage → Blob, which auto-populates BLOB_READ_WRITE_TOKEN.
# When unset, the app falls back to writing uploads/generated/renders into
# ./public (fine for local dev, not usable on read-only serverless FS).
BLOB_READ_WRITE_TOKEN=

# ---- KV (Vercel KV / Upstash Redis) ----
# Required for production deploys. Create a KV store in Vercel → Storage →
# KV, which auto-populates these variables. When unset, session state falls
# back to an in-process Map — only suitable for local dev on a single
# worker.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
