# ---- Music generation ----
# "replicate" = real provider (recommended). Requires REPLICATE_API_TOKEN below.
# "mock"      = local fallback, writes seeded sine-wave stems. Clearly labeled in the UI.
GENERATED_MUSIC_PROVIDER=replicate

# Replicate API token. Required when GENERATED_MUSIC_PROVIDER=replicate.
# Create one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Replicate model to use. Defaults to meta/musicgen. You can swap for compatible models.
REPLICATE_MUSIC_MODEL=meta/musicgen

# ---- Video render / export ----
# "ffmpeg"       = real mix baked into exported MP4 (recommended). Requires ffmpeg on PATH.
# "preview-copy" = honest fallback. Exports a copy of the source video; live in-browser mix
#                  is still audible in the studio, but not baked into the file.
MEDIA_RENDERER_PROVIDER=ffmpeg
FFMPEG_PATH=ffmpeg
